<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Site de Aluguel</title>
   
    <style>
        /* ─── Reset ─── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            background-color: #ffffff;
            color: #333333;
            font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
        }

        /* ─── Navbar ─── */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 64px;
            background-color: #000000;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,0.15);
        }

        .navbar a {
            color: #c9e5ee;
            text-decoration: none;
            margin: 0 24px;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: opacity 0.2s;
        }

        .navbar a:hover {
            opacity: 0.75;
        }

        /* ─── Hero ─── */
        .hero-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding-top: 64px;
            padding-bottom: 60px;
            background: linear-gradient(160deg, #f9f9f9 60%, #ececec 100%);
        }

        .hero-title {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 2.6rem;
            color: #2c2c2c;
            margin-bottom: 10px;
            text-align: center;
        }

        .hero-subtitle {
            font-size: 1rem;
            color: #777;
            margin-bottom: 60px;
            text-align: center;
            letter-spacing: 0.02em;
        }

        /* ─── Vitrine ─── */
        .vitrine-aluguel {
            display: flex;
            gap: 72px;
            justify-content: center;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        /* ─── Card ─── */
        .item-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .item-card img,
        .placeholder-img {
            width: 260px;
            height: 260px;
            background-color: #9b9b9b;
            border-radius: 28px;
            object-fit: cover;
            border: none;
            display: block;
            box-shadow: 0 8px 28px rgba(0,0,0,0.12);
        }

        .item-card .card-label {
            margin-top: 18px;
            font-size: 1rem;
            font-weight: 600;
            color: #444;
            letter-spacing: 0.01em;
        }

        .item-card .card-desc {
            margin-top: 6px;
            font-size: 0.85rem;
            color: #888;
        }

        .btn-alugar {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 44px;
            background-color: #6b6b6b;
            color: #ffffff;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            border-radius: 50px;
            transition: background-color 0.2s, transform 0.15s;
        }

        .btn-alugar:hover {
            background-color: #4a4a4a;
            transform: translateY(-2px);
        }

        /* ─── Seções genéricas ─── */
        section {
            padding: 100px 24px;
            min-height: 70vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            border-top: 1px solid #eeeeee;
        }

        section h2 {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 2rem;
            margin-bottom: 16px;
            color: #2c2c2c;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        section h2 i {
            font-size: 1.5rem;
            color: #8a8a8a;
        }

        section p {
            max-width: 540px;
            color: #666;
            line-height: 1.8;
            font-size: 0.97rem;
        }

        /* ─── Seção de Serviços ─── */
        .servicos-grid {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
            justify-content: center;
            margin-top: 44px;
            max-width: 860px;
        }

        .servico-item {
            background: #f5f5f5;
            border-radius: 20px;
            padding: 32px 24px 28px;
            width: 190px;
            text-align: center;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .servico-item:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.09);
        }

        .servico-item i {
            font-size: 2.2rem;
            color: #6e8a6e;
            margin-bottom: 14px;
            display: block;
        }

        .servico-item .s-title {
            display: block;
            font-size: 0.9rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 6px;
        }

        .servico-item .s-desc {
            display: block;
            font-size: 0.78rem;
            color: #888;
            line-height: 1.5;
        }

        /* ─── Agendamento ─── */
        .agendamento-card {
            margin-top: 40px;
            background: #f7f7f7;
            border-radius: 28px;
            padding: 40px 36px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 6px 32px rgba(0,0,0,0.08);
        }

        /* Cabeçalho do calendário */
        .cal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .cal-header .cal-month {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 1.15rem;
            font-weight: 700;
            color: #2c2c2c;
        }

        .cal-nav {
            background: none;
            border: none;
            cursor: pointer;
            color: #7a7a7a;
            font-size: 1rem;
            padding: 4px 10px;
            border-radius: 8px;
            transition: background 0.15s;
        }

        .cal-nav:hover { background: #e8e8e8; }

        /* Grid dias da semana */
        .cal-weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            margin-bottom: 8px;
        }

        .cal-weekdays span {
            font-size: 0.72rem;
            font-weight: 700;
            color: #aaa;
            text-transform: uppercase;
            padding: 4px 0;
        }

        /* Grid dias */
        .cal-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
            text-align: center;
        }

        .cal-days .day {
            padding: 9px 4px;
            border-radius: 10px;
            font-size: 0.88rem;
            cursor: pointer;
            color: #444;
            transition: background 0.15s, color 0.15s;
            user-select: none;
        }

        .cal-days .day:hover { background: #e2ece2; }

        .cal-days .day.empty { cursor: default; }

        .cal-days .day.today {
            font-weight: 700;
            color: #4a7a4a;
        }

        .cal-days .day.selected {
            background: #6b6b6b;
            color: #fff;
            font-weight: 700;
        }

        .cal-days .day.past {
            color: #ccc;
            cursor: not-allowed;
        }

        /* Divider */
        .cal-divider {
            border: none;
            border-top: 1px solid #e4e4e4;
            margin: 24px 0 20px;
        }

        /* Campos abaixo do calendário */
        .form-agendamento {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .form-agendamento input,
        .form-agendamento select {
            padding: 13px 16px;
            border: 1px solid #ddd;
            border-radius: 12px;
            font-size: 0.93rem;
            font-family: inherit;
            color: #333;
            background: #fff;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-agendamento input:focus,
        .form-agendamento select:focus {
            border-color: #8a8a8a;
        }

        .btn-reserva {
            margin-top: 6px;
            padding: 15px;
            background-color: #6b6b6b;
            color: #fff;
            border: none;
            border-radius: 14px;
            font-size: 0.97rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.15s;
        }

        .btn-reserva:hover {
            background-color: #4a4a4a;
            transform: translateY(-1px);
        }

        .data-selecionada {
            text-align: center;
            font-size: 0.82rem;
            color: #6e8a6e;
            font-weight: 600;
            min-height: 18px;
            margin-top: -4px;
            margin-bottom: 4px;
        }

        /* ─── Local ─── */
        .mapa-placeholder {
            margin-top: 32px;
            width: 100%;
            max-width: 600px;
            height: 260px;
            background: #e8e8e8;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #aaa;
            font-size: 0.9rem;
            gap: 8px;
        }

        /* ─── Footer ─── */
        footer {
            background: #5a5a5a;
            color: #ccc;
            text-align: center;
            padding: 28px 20px;
            font-size: 0.85rem;
            letter-spacing: 0.02em;
        }

        /* ─── Responsivo ─── */
        @media (max-width: 640px) {
            .navbar a { margin: 0 12px; font-size: 12px; }
            .hero-title { font-size: 1.9rem; }
            .vitrine-aluguel { gap: 48px; }
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a href="#sobre"><i class="fas fa-users"></i> Sobre Nós</a>
        <a href="#servicos"><i class="fas fa-cogs"></i> Serviços</a>
        <a href="#agendamento"><i class="fas fa-calendar-alt"></i> Agendamento</a>
        <a href="#local"><i class="fas fa-map-marker-alt"></i> Local</a>
    </nav>

    <!-- Hero / Vitrine -->
    <main class="hero-container">
        <h1 class="hero-title">O que você deseja alugar?</h1>
        <p class="hero-subtitle">Escolha uma das opções abaixo e reserve com facilidade.</p>

        <div class="vitrine-aluguel">

            <!-- Card 1 -->
            <div class="item-card">
                <div class="placeholder-img"></div>
                <span class="card-label">Item A</span>
                <span class="card-desc">Disponível para locação diária</span>
                <a href="#agendamento" class="btn-alugar">Alugar</a>
            </div>

            <!-- Card 2 -->
            <div class="item-card">
                <div class="placeholder-img"></div>
                <span class="card-label">Item B</span>
                <span class="card-desc">Disponível para locação diária</span>
                <a href="#agendamento" class="btn-alugar">Alugar</a>
            </div>

        </div>
    </main>

    <!-- Sobre Nós -->
    <section id="sobre">
        <h2><i class="fas fa-users"></i> Sobre Nós</h2>
        <p>Somos uma empresa dedicada a oferecer a melhor experiência de aluguel, com praticidade, segurança e atendimento personalizado para cada cliente.</p>
    </section>

    <!-- Serviços -->
    <section id="servicos">
        <h2><i class="fas fa-tree"></i> O que a Chácara Oferece</h2>
        <p>Um espaço completo para você aproveitar com família e amigos, com toda estrutura para um dia inesquecível.</p>
        <div class="servicos-grid">
            <div class="servico-item">
                <i class="fas fa-music"></i>
                <span class="s-title">Área de Festa</span>
                <span class="s-desc">Salão coberto ideal para festas e comemorações</span>
            </div>
            <div class="servico-item">
                <i class="fas fa-swimming-pool"></i>
                <span class="s-title">Piscina</span>
                <span class="s-desc">Piscina ampla com área de lazer e espreguiçadeiras</span>
            </div>
            <div class="servico-item">
                <i class="fas fa-home"></i>
                <span class="s-title">Casa Sede</span>
                <span class="s-desc">Sala, cozinha equipada e banheiros para conforto total</span>
            </div>
            <div class="servico-item">
                <i class="fas fa-umbrella-beach"></i>
                <span class="s-title">Áreas de Lazer</span>
                <span class="s-desc">Espaços ao ar livre para relaxar e curtir a natureza</span>
            </div>
        </div>
    </section>

    <!-- Agendamento -->
    <section id="agendamento">
        <h2><i class="fas fa-calendar-alt"></i> Agendamento</h2>
        <p>Selecione a data no calendário e preencha seus dados. Entraremos em contato para confirmar a reserva.</p>

        <div class="agendamento-card">

            <!-- Calendário -->
            <div class="cal-header">
                <button class="cal-nav" id="cal-prev">&#8249;</button>
                <span class="cal-month" id="cal-month-label"></span>
                <button class="cal-nav" id="cal-next">&#8250;</button>
            </div>
            <div class="cal-weekdays">
                <span>Dom</span><span>Seg</span><span>Ter</span>
                <span>Qua</span><span>Qui</span><span>Sex</span><span>Sáb</span>
            </div>
            <div class="cal-days" id="cal-days"></div>
            <p class="data-selecionada" id="data-selecionada"></p>

            <hr class="cal-divider">

            <!-- Formulário -->
            <div class="form-agendamento">
                <input type="text" id="f-nome" placeholder="Seu nome completo">
                <input type="tel" id="f-tel" placeholder="Telefone / WhatsApp">
                <select id="f-item">
                    <option value="" disabled selected>Selecione a chácara</option>
                    <option value="a">Chácara A</option>
                    <option value="b">Chácara B</option>
                </select>
                <button class="btn-reserva" type="button" onclick="solicitarReserva()">Solicitar Reserva</button>
            </div>
        </div>
    </section>

    <script>
        (function() {
            const MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                            'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
            let current = new Date();
            let selectedDate = null;

            function render() {
                const year = current.getFullYear();
                const month = current.getMonth();
                document.getElementById('cal-month-label').textContent =
                    MONTHS[month] + ' ' + year;

                const grid = document.getElementById('cal-days');
                grid.innerHTML = '';

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                const today = new Date();
                today.setHours(0,0,0,0);

                for (let i = 0; i < firstDay; i++) {
                    const empty = document.createElement('div');
                    empty.className = 'day empty';
                    grid.appendChild(empty);
                }

                for (let d = 1; d <= daysInMonth; d++) {
                    const date = new Date(year, month, d);
                    const div = document.createElement('div');
                    div.className = 'day';
                    div.textContent = d;

                    if (date < today) {
                        div.classList.add('past');
                    } else {
                        if (date.toDateString() === today.toDateString()) div.classList.add('today');
                        if (selectedDate && date.toDateString() === selectedDate.toDateString()) div.classList.add('selected');
                        div.addEventListener('click', () => selectDay(date));
                    }
                    grid.appendChild(div);
                }
            }

            function selectDay(date) {
                selectedDate = date;
                const opts = { weekday:'long', day:'numeric', month:'long', year:'numeric' };
                document.getElementById('data-selecionada').textContent =
                    '📅 ' + date.toLocaleDateString('pt-BR', opts);
                render();
            }

            document.getElementById('cal-prev').addEventListener('click', () => {
                current.setMonth(current.getMonth() - 1);
                render();
            });

            document.getElementById('cal-next').addEventListener('click', () => {
                current.setMonth(current.getMonth() + 1);
                render();
            });

            render();

            window.solicitarReserva = function() {
                const nome = document.getElementById('f-nome').value.trim();
                const tel  = document.getElementById('f-tel').value.trim();
                const item = document.getElementById('f-item').value;
                if (!nome || !tel || !item || !selectedDate) {
                    alert('Por favor, preencha todos os campos e selecione uma data no calendário.');
                    return;
                }
                const dateStr = selectedDate.toLocaleDateString('pt-BR');
                alert(`✅ Reserva solicitada!\n\nNome: ${nome}\nData: ${dateStr}\nChácara: ${item}\n\nEntraremos em contato em breve!`);
            };
        })();
    </script>

    <!-- Local -->
    <section id="local">
        <h2><i class="fas fa-map-marker-alt"></i> Local</h2>
        <p>Estamos localizados em um ponto de fácil acesso. Venha nos visitar ou combine a entrega.</p>
        <div class="mapa-placeholder">
            <i class="fas fa-map-marked-alt"></i> Mapa em breve
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2025 Meu Site de Aluguel. Todos os direitos reservados.</p>
    </footer>

</body>
</html>
